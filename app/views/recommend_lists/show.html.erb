<% content_for :title, @recommend_list.title %>

<div class="w-full max-w-3xl mx-auto py-8">
  <div class="mb-6">
    <div class="flex items-start justify-between gap-4 mb-3">
      <% if user_signed_in? && @recommend_list.user == current_user %>
        <p class="inline-block px-3 py-1 text-sm bg-gray-100 text-gray-700 rounded-full"><%= @recommend_list.display_status_label %></p>
      <% end %>

      <% if user_signed_in? && @recommend_list.user == current_user %>
        <div class="flex gap-2 shrink-0">
          <%= link_to "編集する", edit_recommend_list_path(@recommend_list),
                class: "px-4 py-1.5 text-sm font-medium text-white rounded-full transition hover:opacity-90",
                style: "background-color:#22c55e;" %>
          <%= link_to "削除する", @recommend_list,
                data: { turbo_method: :delete, turbo_confirm: "「#{@recommend_list.title}」を削除しますか？\nこの操作は取り消せません。" },
                style: "background-color:#ef4444; color:white;",
                class: "px-4 py-1.5 text-sm font-medium rounded-full hover:opacity-90 transition" %>
        </div>
      <% end %>
    </div>

    <h1 class="text-2xl font-bold text-gray-800 mt-3"><%= @recommend_list.title %></h1>
    <% if @recommend_list.description.present? %>
      <p class="mt-2 text-gray-600"><%= @recommend_list.description %></p>
    <% end %>
  </div>

  <h2 class="text-lg font-bold text-gray-800 mb-3">推しコミリスト</h2>
  <div class="space-y-4">
    <% @recommend_list.recommend_list_items.each do |item| %>
      <div class="border border-gray-200 rounded-lg p-4 bg-white flex gap-4">
        <div class="flex-shrink-0">
          <% if item.book.image_url.present? %>
            <%= image_tag item.book.image_url, alt: item.book.title,
                  class: "w-20 h-28 shrink-0 object-cover rounded shadow-sm" %>
          <% else %>
            <div class="w-20 h-28 bg-gray-100 rounded flex items-center justify-center text-xs text-gray-400 text-center">
              書影<br>なし
            </div>
          <% end %>
        </div>

        <div class="flex-1 min-w-0">
          <p class="font-semibold text-gray-800"><%= item.book.title %></p>
          <p class="text-sm text-gray-500"><%= item.book.author.presence || "著者未登録" %></p>
          <% if item.comment.present? %>
            <p class="mt-3 text-sm text-gray-700 border-l-2 border-green-400 pl-3 italic"><%= item.comment %></p>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
