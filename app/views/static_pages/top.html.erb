<div class="w-full min-h-screen bg-gradient-to-b from-green-100 via-green-50 to-white flex flex-col items-center justify-center -mt-16 pt-16">
  <div class="text-center px-8">
    <h1 class="text-4xl font-bold mb-4" style="color:#22c55e;">推しコミリマインダー</h1>
    <p class="text-gray-600 text-lg mb-2">お気に入り漫画の更新日をメールで受け取ろう</p>

    <div class="mt-8 flex flex-col items-center gap-4">
      <%= link_to register_path,
            class: "w-64 inline-flex items-center justify-center px-8 py-4 bg-green-500 text-white font-bold rounded-full shadow hover:bg-green-600 transition" do %>
        新規登録
      <% end %>
      <p class="text-sm text-gray-500">
        アカウントをお持ちの方は
        <%= link_to "ログイン", login_path, class: "font-bold text-green-600 hover:underline" %>
      </p>
    </div>

      <%= link_to recommend_lists_path,
            class: "mt-8 inline-flex items-center gap-2 px-8 py-4 bg-white text-green-600 text-base font-bold border-2 border-green-300 rounded-full shadow hover:bg-green-50 hover:border-green-500 transition" do %>
        みんなの推しコミリストを見る
      <% end %>
    </div>
  </div>
</div>
