<% content_for :title, "リマインダー" %>

<div class="w-full max-w-2xl mx-auto py-8">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-800">リマインダー</h1>
    <%= link_to "追加", new_reminder_path,
          data: { turbo_frame: "modal" },
          style: "background-color:#22c55e; color:white;",
          class: "px-4 py-2 text-sm font-medium rounded-full hover:opacity-90 transition" %>
  </div>

  <p id="reminders_empty" class="text-center text-gray-400 py-16 <%= 'hidden' unless @reminders.empty? %>">
    リマインダーが登録されていません
  </p>

  <div id="reminders_list" class="space-y-4">
    <%= render @reminders %>
  </div>
</div>
