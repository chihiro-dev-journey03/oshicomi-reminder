<% content_for :title, "リマインダー" %>

<div class="w-full max-w-2xl mx-auto py-8">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-800">リマインダー</h1>
    <%= link_to "追加", new_reminder_path,
          class: "px-4 py-2 text-sm font-medium bg-pink-500 text-white rounded-full hover:bg-pink-600 transition" %>
  </div>

  <div class="space-y-4">
    <% @reminders.each do |reminder| %>
      <div class="bg-white border border-gray-200 rounded-lg p-4 shadow-sm">
        <div class="flex items-center justify-between">
          <div class="flex-1 min-w-0">
            <p class="font-semibold text-gray-800 truncate"><%= reminder.book.title %></p>
            <p class="text-sm text-gray-500 mt-1"><%= l(reminder.scheduled_at, format: :long) %></p>
          </div>
          <div class="flex items-center gap-2 ml-4 shrink-0">
            <span class="<%= status_badge_class(reminder.status) %>">
              <%= t("reminder.status.#{reminder.status}") %>
            </span>
            <%= link_to "編集", edit_reminder_path(reminder),
                  class: "px-3 py-1 text-sm bg-gray-100 text-gray-600 rounded hover:bg-gray-200 transition" %>
            <%= button_to "削除", reminder_path(reminder), method: :delete,
                  data: { turbo_confirm: "このリマインダーを削除しますか？" },
                  class: "px-3 py-1 text-sm bg-gray-100 text-gray-600 rounded hover:bg-gray-200 transition" %>
          </div>
        </div>
        <% if reminder.memo.present? %>
          <p class="text-sm text-gray-600 mt-2"><%= reminder.memo %></p>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
