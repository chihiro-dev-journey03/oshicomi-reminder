<% content_for :title, "リマインダー" %>

<div class="w-full max-w-2xl mx-auto py-8">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-4xl font-bold" style="color:#22c55e;">リマインダー</h1>
    <div class="flex items-center gap-2">
      <%= link_to "推しコミリストを作成", new_recommend_list_path,
            class: "px-4 py-2 text-sm font-medium rounded-full bg-gray-100 text-gray-700 hover:bg-gray-200 transition" %>
      <%= link_to "追加", new_reminder_path,
            data: { turbo_frame: "modal" },
            style: "background-color:#22c55e; color:white;",
            class: "px-4 py-2 text-sm font-medium rounded-full hover:opacity-90 transition" %>
    </div>
  </div>

  <p id="reminders_empty" class="text-center text-gray-400 py-16 <%= 'hidden' unless @reminders.empty? %>">
    リマインダーが登録されていません
  </p>

  <div id="reminders_list" class="space-y-4">
    <%= render @reminders %>
  </div>
</div>
