<turbo-frame id="modal">
    <div style="position:fixed;inset:0;z-index:50;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,0.4);"
         data-controller="reminder-form"
         data-action="click->reminder-form#closeOnBackdrop">

    <div style="background:white;border-radius:1rem;box-shadow:0 20px 40px rgba(0,0,0,0.15);width:100%;max-width:32rem;margin:0 1rem;overflow-y:auto;max-height:90vh;"
         data-reminder-form-target="dialog">

      <%# ヘッダー %>
      <div class="flex items-center justify-between px-6 pt-5 pb-4 border-b border-gray-100">
        <h2 class="text-lg font-bold text-gray-800">リマインダー登録</h2>
        <button type="button"
                data-action="reminder-form#close"
                class="text-gray-400 hover:text-gray-600 transition">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <%= form_with model: @reminder, url: reminders_path, data: { reminder_form_target: "form" } do |f| %>
        <div class="px-6 py-5 space-y-5">

          <%# バリデーションエラー表示 %>
          <% if @reminder.errors.any? %>
            <div class="rounded-lg bg-red-50 border border-red-200 px-4 py-3">
              <ul class="list-disc list-inside text-sm text-red-600 space-y-1">
                <% @reminder.errors.each do |error| %>
                  <li><%= error.full_message %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <%# マンガタイトル %>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
              マンガタイトル <span class="text-xs text-red-500">必須</span>
            </label>
            <%= text_field_tag "reminder[book_title]",
                  params.dig(:reminder, :book_title),
                  placeholder: "",
                  class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-400" %>
          </div>

          <%# リマインド日時 %>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">
              リマインド日時 <span class="text-xs text-red-500">必須</span>
            </label>

            <%# 繰り返す間隔（数値 + タイプ選択） %>
            <div class="flex items-center gap-2 mb-4">
              <%= f.number_field :recurrence_interval,
                    min: 1,
                    data: { reminder_form_target: "intervalInput" },
                    class: "w-16 border border-gray-300 rounded-lg px-2 py-2 text-sm text-center focus:outline-none focus:ring-2 focus:ring-green-400" %>
              <%= f.select :recurrence_type,
                    options_for_select(
                      [["日ごと", "daily"], ["週ごと", "weekly"], ["ヶ月ごと", "monthly"]],
                      @reminder.recurrence_type
                    ),
                    {},
                    data: { action: "change->reminder-form#switchRecurrence",
                            reminder_form_target: "recurrenceSelect" },
                    class: "flex-1 border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-400" %>
            </div>

            <%# 日ごとセクション %>
            <div data-reminder-form-target="dailySection">
              <%= render "reminders/time_fields", f: f %>
            </div>

            <%# 週ごとセクション %>
            <div data-reminder-form-target="weeklySection" class="hidden">
              <div class="mb-3">
                <p class="text-xs text-gray-500 mb-2">曜日（複数選択可）</p>
                <div class="flex gap-1.5 flex-wrap">
                  <% Reminder::DAYS_OF_WEEK_BITS.each do |bit, label| %>
                    <label class="cursor-pointer">
                      <input type="checkbox"
                             name="reminder[days_of_week_array][]"
                             value="<%= bit %>"
                             class="sr-only peer"
                             data-action="change->reminder-form#updateDayButtons"
                             <%= "checked" if @reminder.days_of_week_array.include?(bit) %>>
                      <span class="block w-9 h-9 flex items-center justify-center text-sm rounded-full border border-gray-300 peer-checked:text-white peer-checked:border-transparent transition"
                            style="<%= "background-color:#22c55e;" if @reminder.days_of_week_array.include?(bit) %>"
                            data-reminder-form-target="dayButton">
                        <%= label %>
                      </span>
                    </label>
                  <% end %>
                </div>
              </div>
              <%= render "reminders/time_fields", f: f %>
            </div>

            <%# ヶ月ごとセクション %>
            <div data-reminder-form-target="monthlySection" class="hidden">
              <div class="mb-3 space-y-3">
                <%# 日付指定 %>
                <label class="flex items-center gap-2 cursor-pointer">
                  <%= f.radio_button :monthly_type, "date",
                        data: { action: "change->reminder-form#switchMonthlyType" },
                        class: "accent-green-500" %>
                  <span class="text-sm text-gray-700">日付で指定：</span>
                  <%= f.select :day_of_month,
                        options_for_select((1..31).map { |d| [d.to_s, d] }, @reminder.day_of_month || 1),
                        {},
                        class: "border border-gray-300 rounded px-2 py-1 text-sm focus:outline-none focus:ring-1 focus:ring-green-400",
                        data: { reminder_form_target: "dateSelect" } %>
                  <span class="text-sm text-gray-700">日</span>
                </label>

                <%# 曜日指定 %>
                <label class="flex items-center gap-2 cursor-pointer">
                  <%= f.radio_button :monthly_type, "weekday",
                        data: { action: "change->reminder-form#switchMonthlyType" },
                        class: "accent-green-500" %>
                  <span class="text-sm text-gray-700">曜日で指定：</span>
                  <div class="flex items-center gap-1"
                       data-reminder-form-target="weekdaySelect">
                    <%= f.select :week_of_month,
                          options_for_select([["最初の", 1], ["第二", 2], ["第三", 3], ["第四", 4], ["最後の", 5]], @reminder.week_of_month || 1),
                          {},
                          class: "border border-gray-300 rounded px-2 py-1 text-sm focus:outline-none focus:ring-1 focus:ring-green-400" %>
                    <%= f.select :weekday,
                          options_for_select(Reminder::DAYS_OF_WEEK_BITS.map { |k, v| ["#{v}曜日", k] }, @reminder.weekday || 0),
                          {},
                          class: "border border-gray-300 rounded px-2 py-1 text-sm focus:outline-none focus:ring-1 focus:ring-green-400" %>
                  </div>
                </label>
              </div>
              <%= render "reminders/time_fields", f: f %>
            </div>
          </div>

          <%# メモ %>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
              メモ <span class="text-xs text-gray-400">任意</span>
            </label>
            <%= f.text_area :memo,
                  rows: 2,
                  placeholder: "",
                  class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-400 resize-none" %>
          </div>

        </div>

        <%# フッターボタン %>
        <div class="flex justify-end gap-3 px-6 py-4 border-t border-gray-100">
          <button type="button"
                  data-action="reminder-form#close"
                  class="px-5 py-2 text-sm text-gray-600 bg-gray-100 rounded-full hover:bg-gray-200 transition">
            キャンセル
          </button>
          <%= f.submit "保存",
                style: "background-color:#22c55e; color:white;",
                class: "px-6 py-2 text-sm font-medium rounded-full hover:opacity-90 transition cursor-pointer" %>
        </div>

      <% end %>
    </div>
  </div>
</turbo-frame>
